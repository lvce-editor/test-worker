{
  "name": "@lvce-editor/test-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "npm exec --workspace=packages/build -- esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/test-worker/src/testWorkerMain.ts --outfile=.tmp/dist/dist/testWorkerMain.js",
    "dev": "node packages/build/src/dev.ts",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "measure": "npm run measure --workspace=packages/memory",
    "test": "npm test --workspaces --if-present",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lvce-editor/eslint-config": "^16.4.0",
    "@lvce-editor/eslint-plugin-github-actions": "^16.4.0",
    "@lvce-editor/eslint-plugin-regex": "^16.4.0",
    "@lvce-editor/eslint-plugin-tsconfig": "^16.4.0",
    "@types/node": "^25.9.3",
    "eslint": "^10.7.0",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
